{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "https://contractlens-ai.onrender.com/api/$1" 
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}